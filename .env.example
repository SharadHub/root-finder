# Environment Variables for RootFinder
# Copy this file to .env.local and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps API (for map integration)
# VITE_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# (Maps integration is optional for now)

# Admin Authentication (for simple admin login)
ADMIN_SECRET_KEY=your_admin_secret_key

# Booking Affiliate IDs
BOOKING_COM_AFFILIATE_ID=your_booking_com_id
AGODA_AFFILIATE_ID=your_agoda_id
